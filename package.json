{
  "name": "antigravity_carrental",
  "version": "1.0.0",
  "description": "Car Rental Management System - Node.js + TypeScript + MVCR",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,ejs --exec \"ts-node src/app.ts\"",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed": "ts-node src/seed.ts"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "keywords": [
    "car-rental",
    "nodejs",
    "typescript",
    "express",
    "mongoose"
  ],
  "author": "antigravity",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
