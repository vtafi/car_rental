<%- include('../partials/header') %>

<div class="page-header">
  <h1><%= booking ? '✏️ Sửa đặt xe' : '➕ Tạo đặt xe mới' %></h1>
  <a href="/bookings" class="btn btn-ghost">← Quay lại</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error">❌ <%= error %></div>
<% } %>

<div class="card" style="max-width:680px">
  <div class="card-body">
    <form action="<%= booking ? `/bookings/${booking._id}/update` : '/bookings' %>" method="POST">

      <div class="form-group">
        <label for="customerName">Tên khách hàng *</label>
        <input type="text" id="customerName" name="customerName"
          value="<%= booking ? booking.customerName : '' %>"
          placeholder="Nguyễn Văn A" required />
      </div>

      <div class="form-group">
        <label for="carNumber">Biển số xe *</label>
        <select id="carNumber" name="carNumber" required>
          <option value="">-- Chọn xe --</option>
          <% cars.forEach(car => { %>
            <option value="<%= car.carNumber %>"
              <%= (booking && booking.carNumber === car.carNumber) || (!booking && car.status === 'available') ? '' : '' %>
              <%= (booking && booking.carNumber === car.carNumber) ? 'selected' : '' %>
              <%= (!booking && car.status !== 'available') ? 'disabled' : '' %>
            >
              <%= car.carNumber %> – <%= car.capacity %> chỗ – <%= car.pricePerDay.toLocaleString('vi-VN') %>₫/ngày
              (<%= car.status %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="startDate">Ngày bắt đầu *</label>
          <input type="date" id="startDate" name="startDate"
            value="<%= booking ? new Date(booking.startDate).toISOString().split('T')[0] : '' %>"
            required />
        </div>
        <div class="form-group">
          <label for="endDate">Ngày kết thúc *</label>
          <input type="date" id="endDate" name="endDate"
            value="<%= booking ? new Date(booking.endDate).toISOString().split('T')[0] : '' %>"
            required />
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">
          💾 <%= booking ? 'Cập nhật' : 'Tạo đặt xe' %>
        </button>
        <a href="/bookings" class="btn btn-ghost">Huỷ</a>
      </div>
    </form>
  </div>
</div>

<script>
  // Auto-set min date for startDate
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('startDate').min = today;
  document.getElementById('startDate').addEventListener('change', e => {
    document.getElementById('endDate').min = e.target.value;
  });
</script>

<%- include('../partials/footer') %>
