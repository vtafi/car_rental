<%- include('../partials/header') %>

<% if (typeof message !== 'undefined' && message) { %>
  <div class="alert alert-<%= messageType || 'info' %>"><%= message %></div>
<% } %>

<div class="page-header">
  <h1>🚘 Quản lý xe</h1>
  <a href="/cars/new" class="btn btn-primary">+ Thêm xe mới</a>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">Danh sách xe (<%= cars.length %>)</span>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Biển số</th>
          <th>Sức chứa</th>
          <th>Giá/ngày</th>
          <th>Tính năng</th>
          <th>Trạng thái</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (cars.length === 0) { %>
          <tr><td colspan="6" class="table-empty">🚗 Chưa có xe nào. <a href="/cars/new">Thêm xe ngay!</a></td></tr>
        <% } %>
        <% cars.forEach(car => { %>
          <tr>
            <td><strong><%= car.carNumber %></strong></td>
            <td><%= car.capacity %> chỗ</td>
            <td><%= car.pricePerDay.toLocaleString('vi-VN') %>₫</td>
            <td>
              <% if (car.features && car.features.length > 0) { %>
                <% car.features.slice(0,3).forEach(f => { %>
                  <span class="badge badge-available" style="margin:2px"><%= f %></span>
                <% }) %>
                <% if (car.features.length > 3) { %><small style="color:var(--text-muted)">+<%= car.features.length - 3 %></small><% } %>
              <% } else { %>
                <span style="color:var(--text-muted)">–</span>
              <% } %>
            </td>
            <td><span class="badge badge-<%= car.status %>"><%= car.status %></span></td>
            <td>
              <div style="display:flex;gap:6px;flex-wrap:wrap">
                <a href="/cars/<%= car._id %>/edit" class="btn btn-warning btn-sm">✏️ Sửa</a>
                <form action="/cars/<%= car._id %>/delete" method="POST" style="display:inline">
                  <button type="submit" class="btn btn-danger btn-sm"
                    data-confirm="Xoá xe <%= car.carNumber %>?">🗑️ Xoá</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
